{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"exactOptionalPropertyTypes": true,
		"noUncheckedIndexedAccess": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"ignoreDeprecations": "6.0",
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"types": ["node", "vitest"]
	},
	"include": ["src", "test", "*.config.ts"]
}
