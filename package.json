{
	"name": "@crazyhappyone/auto-graph",
	"version": "0.0.6",
	"description": "Deterministic geometry computation engine for diagrams",
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zhangyang-crazy-one/auto-graph.git"
	},
	"bugs": {
		"url": "https://github.com/zhangyang-crazy-one/auto-graph/issues"
	},
	"homepage": "https://github.com/zhangyang-crazy-one/auto-graph#readme",
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=20"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"agh": "./dist/cli/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist",
		"README.md",
		"README.zh-CN.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"lint": "biome ci .",
		"format": "biome check --write .",
		"verify": "npm run typecheck && npm run build && npm test && npm run lint"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/node": "25.9.1",
		"tsup": "8.5.1",
		"typescript": "6.0.3",
		"vitest": "4.1.7"
	},
	"dependencies": {
		"@chenglou/pretext": "^0.0.7",
		"@dagrejs/dagre": "^3.0.0",
		"@napi-rs/canvas": "^1.0.0",
		"commander": "^14.0.3",
		"yaml": "^2.9.0",
		"zod": "^4.4.3"
	}
}
